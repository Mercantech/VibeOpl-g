# Kopier til .env og udfyld værdier (commit aldrig .env)
APP_ACCESS_PASSWORD=skift-mig
DISCORD_URL=https://discord.gg/7XU65xmWb5
DATABASE_URL=postgresql://vibeoplg:vibeoplg@db:5432/vibeoplg
SECRET_KEY=skift-til-en-lang-tilfaeldig-streng
CORS_ORIGINS=http://localhost:5173,http://localhost,http://localhost:4010

# Host-porte (Docker → maskine). Cloudflare Tunnel peger typisk på WEB_HOST_PORT.
WEB_HOST_PORT=4010
MINIO_API_HOST_PORT=4011
MINIO_CONSOLE_HOST_PORT=4012

# Lagring: "minio" (Docker) eller "local" (lokal udvikling uden MinIO)
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=vibeoplg
MINIO_SECRET_KEY=vibeoplgsecret
MINIO_BUCKET=vibeoplg
MINIO_SECURE=false
UPLOAD_DIR=/data/uploads
